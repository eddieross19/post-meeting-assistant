        <content>Provide raw json formatted output in the format from below.
Based on raw meetings notes, analyze and populate this json 

Meeting notes: &quot;&quot;&quot;{!$Input:Meeting_Notes}&quot;&quot;&quot;

Json Format: 
&quot;&quot;&quot;
{
 &quot;event&quot;: {
  &quot;event_name&quot;: &quot;String&quot;,
  &quot;event_date&quot;: &quot;ISO-8601 (YYYY-MM-DDThh:mm:ssZ)&quot;,
  &quot;event_attendee&quot;: &quot;String&quot;
 },
 &quot;tasks&quot;: [
  {
   &quot;task_name&quot;: &quot;String&quot;,
   &quot;task_due_date&quot;: &quot;ISO-8601 (YYYY-MM-DD)&quot;,
   &quot;task_priority&quot;: &quot;String (Low | Normal | High)&quot;
  },
  {
   &quot;task_name&quot;: &quot;String&quot;,
   &quot;task_due_date&quot;: &quot;ISO-8601 (YYYY-MM-DD)&quot;,
   &quot;task_priority&quot;: &quot;String (Low | Medium | High)&quot;
  }
 ],
 &quot;opportunity&quot;: {
  &quot;opportunity_name&quot;: &quot;String&quot;,
  &quot;opportunity_close_date&quot;: &quot;ISO-8601 (YYYY-MM-DD)&quot;,
  &quot;opportunity_amount&quot;: &quot;Float / Decimal&quot;
 }
}
&quot;&quot;&quot;
</content>
        <fileDroppingStrategy>{&quot;dropFilesBy&quot;:&quot;LAST_MODIFIED_DATE&quot;,&quot;dropFileStartingWith&quot;:&quot;OLDEST&quot;}</fileDroppingStrategy>
